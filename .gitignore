# Default private: ignore everything unless explicitly allowlisted below.
*

# Keep traversing directories so allowlist rules can reach nested files.
!*/

# Public root docs/config.
!/.gitignore
!/README.md

# Public bridge package.
!/OpenJane/
!/OpenJane/bridges/
!/OpenJane/bridges/openclaw/
